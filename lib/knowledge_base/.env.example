# Environment variables for knowledge_base project
# Copy this file to .env and fill in your actual values

# KIMI API Configuration
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL_NAME=moonshot-v1-8k
KIMI_MAX_TOKENS=8192
KIMI_TEMPERATURE=0.7

# Firecrawl API (for web crawling)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
FIRECRAWL_RATE_LIMIT=30
FIRECRAWL_TIMEOUT=60
FIRECRAWL_MAX_RETRIES=3
FIRECRAWL_RETRY_DELAY=5

# Storage Configuration
NOVEL_OUTPUT_DIR=./novels_output
NOVEL_DEDUP_ENABLED=true
NOVEL_DEDUP_CACHE_SIZE=10000

# Crawler Configuration
CRAWLER_LOG_LEVEL=INFO
CRAWLER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Fanqie (番茄小说网) Publishing
FANQIE_BOOK_ID=your_fanqie_book_id
FANQIE_VOLUME_ID=your_fanqie_volume_id
FANQIE_UPLOAD_DELAY=5
